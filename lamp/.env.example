# ============================================================
# 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# ────────────────────────────────────────
# ホスト側ユーザーの UID / GID
# WSL / Linux で以下のコマンドで確認
# id -u
# id -g
#
# 今回は確認済みのため 1000 / 1000 で固定
# ────────────────────────────────────────
UID=1000
GID=1000

# ────────────────────────────────────────
# MySQL
# ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# ────────────────────────────────────────
# phpMyAdmin
# ────────────────────────────────────────
PMA_USER=root
PMA_PASSWORD=rootpassword