# ============================================================
# 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# ────────────────────────────────────────
# MySQL
# ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# ────────────────────────────────────────
# phpMyAdmin（常時起動）
# ────────────────────────────────────────
PMA_USER=root
PMA_PASSWORD=rootpassword
