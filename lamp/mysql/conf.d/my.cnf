# ============================================================
# MySQL 8.4 チューニング設定（XServer準拠）
# ============================================================

[mysqld]

# ────────────────────────────────────────
# 文字コード（utf8mb4 統一）
# ────────────────────────────────────────
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
character-set-filesystem    = utf8mb4
init_connect                = 'SET NAMES utf8mb4'

# ────────────────────────────────────────
# バックアップ・インポート安定化
# ────────────────────────────────────────
# 大容量SQLダンプのインポートに対応
max_allowed_packet          = 256M
# 一括INSERTを高速化
bulk_insert_buffer_size     = 64M
# インポート中のタイムアウト延長
net_read_timeout            = 300
net_write_timeout           = 300
wait_timeout                = 600
interactive_timeout         = 600
# LOAD DATA INFILE を許可
local_infile                = ON

# ────────────────────────────────────────
# InnoDB パフォーマンス（XServer相当）
# ────────────────────────────────────────
# バッファプール: Docker環境は512M推奨（物理メモリの50〜70%が目安）
innodb_buffer_pool_size     = 512M
innodb_buffer_pool_instances = 2
# Redoログ容量（書き込み負荷が高い環境ほど大きく）
innodb_redo_log_capacity    = 256M
# SSD環境向けI/O最適化
innodb_flush_method         = O_DIRECT
# クラッシュ耐性（1=最安全・コミットごとに同期）
innodb_flush_log_at_trx_commit = 1
# デッドロック自動検出
innodb_deadlock_detect      = ON
# I/Oスレッド数
innodb_read_io_threads      = 4
innodb_write_io_threads     = 4
# 高並列INSERT向けオートインクリメントロック最適化
innodb_autoinc_lock_mode    = 2
# 再起動後もクエリプランを安定させる
innodb_stats_persistent     = ON

# ────────────────────────────────────────
# クエリ・バッファ最適化
# ────────────────────────────────────────
# スロークエリログ（1秒超のクエリを記録）
slow_query_log              = ON
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 1
log_queries_not_using_indexes = ON
# テーブルキャッシュ
table_open_cache            = 4000
table_definition_cache      = 2000
# ソート・結合バッファ
sort_buffer_size            = 4M
join_buffer_size            = 4M
read_buffer_size            = 2M
read_rnd_buffer_size        = 4M

# ────────────────────────────────────────
# 接続・スレッド管理
# ────────────────────────────────────────
max_connections             = 150
max_connect_errors          = 100000
thread_cache_size           = 16
back_log                    = 128

# ────────────────────────────────────────
# 一時テーブル
# ────────────────────────────────────────
tmp_table_size              = 64M
max_heap_table_size         = 64M
tmpdir                      = /tmp

# ────────────────────────────────────────
# SQL モード（データ整合性を厳格に担保）
# ────────────────────────────────────────
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# ────────────────────────────────────────
# その他
# ────────────────────────────────────────
key_buffer_size             = 32M
performance_schema          = ON

# ────────────────────────────────────────
# ログ
# ────────────────────────────────────────
log_error                   = /var/log/mysql/error.log
general_log                 = OFF

# ────────────────────────────────────────
# バイナリログ（本番障害復旧向け・開発時はコメントアウト推奨）
# ────────────────────────────────────────
# log_bin                   = /var/log/mysql/mysql-bin.log
# expire_logs_days          = 7
# max_binlog_size           = 100M

[client]
default-character-set       = utf8mb4

[mysql]
default-character-set       = utf8mb4

[mysqldump]
default-character-set       = utf8mb4
max_allowed_packet          = 256M
